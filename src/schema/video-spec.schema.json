{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://video-maker.local/schema/video-spec.schema.json",
  "title": "VideoSpec",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "profile", "format", "language", "captionPolicy", "scenes", "publishTargets", "quality"],
  "properties": {
    "id": { "type": "string", "minLength": 1 },
    "profile": { "type": "string", "minLength": 1 },
    "mode": { "type": "string", "minLength": 1 },
    "sourceProject": { "type": "string" },
    "title": { "type": "string" },
    "description": { "type": "string" },
    "language": { "type": "string", "minLength": 2 },
    "format": {
      "type": "object",
      "additionalProperties": false,
      "required": ["width", "height", "fps", "durationSec"],
      "properties": {
        "width": { "type": "integer", "minimum": 1 },
        "height": { "type": "integer", "minimum": 1 },
        "fps": { "type": "integer", "minimum": 1 },
        "durationSec": { "type": "number", "exclusiveMinimum": 0 }
      }
    },
    "captionPolicy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["mode"],
      "properties": {
        "mode": { "enum": ["burned", "sidecar", "none"] },
        "format": { "enum": ["srt", "vtt", "ass"] },
        "required": { "type": "boolean" }
      }
    },
    "scenes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "startSec", "durationSec", "narration", "visual"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "startSec": { "type": "number", "minimum": 0 },
          "durationSec": { "type": "number", "exclusiveMinimum": 0 },
          "narration": { "type": "string" },
          "visual": {
            "type": "object",
            "additionalProperties": true,
            "required": ["kind"],
            "properties": {
              "kind": { "type": "string", "minLength": 1 },
              "prompt": { "type": "string" },
              "assetRefs": {
                "type": "array",
                "items": { "type": "string" }
              },
              "components": {
                "type": "array",
                "items": { "type": "string" }
              }
            }
          },
          "story": {
            "type": "object",
            "additionalProperties": true
          }
        }
      }
    },
    "assets": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "kind", "uri"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "kind": { "enum": ["image", "video", "audio", "html", "json", "font", "other"] },
          "uri": { "type": "string", "minLength": 1 },
          "license": { "type": "string" },
          "role": { "type": "string" }
        }
      }
    },
    "publishTargets": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "quality": {
      "type": "object",
      "additionalProperties": true,
      "required": ["gates"],
      "properties": {
        "gates": {
          "type": "array",
          "items": { "type": "string" }
        },
        "transformativeNote": { "type": "string" },
        "requiresManualReview": { "type": "boolean" }
      }
    },
    "metadata": {
      "type": "object",
      "additionalProperties": true
    },
    "transformative": {
      "type": "object",
      "additionalProperties": true
    },
    "platformVariants": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true
      }
    }
  }
}
